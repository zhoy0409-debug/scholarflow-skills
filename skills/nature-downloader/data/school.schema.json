{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarflow.skills/schemas/school-access.schema.json",
  "title": "School Access Configuration",
  "description": "Configuration used by nature-downloader to remember an institution's access route.",
  "type": "object",
  "required": [
    "version",
    "school",
    "access",
    "libraries"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Configuration schema version."
    },
    "updated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp for the last update."
    },
    "school": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Institution name."
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source": {
          "type": "string",
          "description": "preset, manual, or resource_url."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "access": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "cas",
            "sso",
            "ezproxy",
            "webvpn",
            "custom"
          ]
        },
        "sso_domain": {
          "type": "string"
        },
        "carsi_entry": {
          "type": "string"
        },
        "ezproxy_url": {
          "type": "string"
        },
        "resource_entry": {
          "type": "string"
        }
      }
    },
    "libraries": {
      "type": "array",
      "description": "Databases or publisher platforms available through the institution.",
      "items": {
        "type": "string"
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
