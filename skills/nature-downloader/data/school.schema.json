{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SchoolConfig",
  "description": "English text schema, English text ~/.config/lit-dl/school.json",
  "type": "object",
  "required": ["version", "school", "auth", "libraries"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "English text, English text",
      "const": 1
    },
    "school": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "description": "English text"
        },
        "code": {
          "type": ["string", "null"],
          "description": "English text/English text"
        },
        "configured_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "English text ISO 8601"
        },
        "source": {
          "type": ["string", "null"],
          "enum": ["preset", "manual", "resource_url", null],
          "description": "English text: English text / English text / English text"
        }
      }
    },
    "auth": {
      "type": "object",
      "required": ["type", "sso_domain"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cas", "jaccount", "uis", "ustp", "sso", "custom"],
          "description": "English text"
        },
        "sso_domain": {
          "type": "string",
          "description": "English text, English text jaccount.sjtu.edu.cn"
        },
        "carsi_entry": {
          "type": ["string", "null"],
          "description": "CARSI English text URL"
        },
        "carsi_sp_entity_id": {
          "type": ["string", "null"],
          "description": "CARSI SP EntityID(English text)"
        }
      }
    },
    "proxy": {
      "type": "object",
      "properties": {
        "type": {
          "type": ["string", "null"],
          "enum": ["ezproxy", null],
          "description": "English text"
        },
        "ezproxy_url": {
          "type": ["string", "null"],
          "description": "EZproxy English text"
        }
      }
    },
    "libraries": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "English text, English text"
    },
    "discovery": {
      "type": "object",
      "properties": {
        "web_of_science_url": {
          "type": ["string", "null"],
          "description": "Web of Science / English text"
        },
        "resource_entry_url": {
          "type": ["string", "null"],
          "description": "English text"
        },
        "resource_portal_url": {
          "type": ["string", "null"],
          "description": "English text"
        },
        "auth_service_host": {
          "type": ["string", "null"],
          "description": "English text"
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "string",
      "default": "",
      "description": "English text"
    },
    "_warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "English text(English text)"
    }
  },
  "additionalProperties": false
}
