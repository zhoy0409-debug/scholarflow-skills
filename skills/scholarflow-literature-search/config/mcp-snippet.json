{
  "mcpServers": {
    "academic-search": {
      "command": "uv",
      "args": [
        "run",
        "--no-project",
        "--directory",
        "<MCP_SERVER_DIR>",
        "--with",
        "mcp>=1.0.0,<2.0.0",
        "--with",
        "requests>=2.28.0,<3.0.0",
        "--with",
        "toml>=0.10.2,<2.0.0",
        "--with",
        "lxml>=4.9.0,<6.0.0",
        "--with",
        "pybliometrics>=4.4.1,<5.0.0",
        "python",
        "academic_search_server.py"
      ]
    }
  }
}
