# Publication-style PyMOL defaults for protein-ligand figures.
bg_color white
set ray_opaque_background, off
set antialias, 2
set orthoscopic, on
set depth_cue, off
set ray_trace_mode, 1
set cartoon_fancy_helices, on
set cartoon_smooth_loops, on
set cartoon_highlight_color, grey90
set stick_radius, 0.18
set sphere_scale, 0.25
set dash_color, black
set dash_width, 2.0
set dash_gap, 0.25
set dash_radius, 0.04
set label_size, 16
set label_color, black
set label_outline_color, white
set label_distance_digits, 2
set valence, on
set ray_shadow, off
set ambient, 0.45
set direct, 0.55
set specular, 0.2
set shininess, 20
