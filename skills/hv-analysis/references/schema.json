{
  "$schema": "https://scholarflow.skills/schemas/horizontal-vertical-analysis.schema.json",
  "version": "1.0",
  "description": "Reference structure for horizontal-vertical analysis: compare a topic across time, evidence layers, competing explanations, and decision implications.",
  "meta": {
    "project": {
      "title": "string",
      "domain": "string",
      "research_question": "string",
      "audience": "string",
      "created_at": "ISO-8601 date",
      "analyst": "string",
      "status": "draft | reviewed | final"
    }
  },
  "horizontal_analysis": {
    "definition": "Compare peer cases, schools of thought, products, labs, or journals at the same level.",
    "entities": [
      {
        "name": "string",
        "type": "paper | method | product | institution | competitor | journal",
        "positioning": "string",
        "strengths": [
          "string"
        ],
        "weaknesses": [
          "string"
        ],
        "evidence_sources": [
          "url or citation"
        ],
        "notes": "string"
      }
    ],
    "comparison_axes": [
      {
        "axis": "string",
        "why_it_matters": "string",
        "scoring_rule": "string",
        "entity_scores": {
          "entity_name": "score or qualitative rating"
        }
      }
    ],
    "patterns": [
      "string"
    ],
    "outliers": [
      "string"
    ],
    "decision_implications": [
      "string"
    ]
  },
  "vertical_analysis": {
    "definition": "Trace how an idea, evidence chain, market, or method changes over time and depth.",
    "timeline": [
      {
        "date_or_stage": "string",
        "event": "string",
        "evidence": "citation or source",
        "interpretation": "string",
        "confidence": "low | medium | high"
      }
    ],
    "causal_layers": [
      {
        "layer": "surface | mechanism | constraint | incentive | system",
        "claim": "string",
        "supporting_evidence": [
          "string"
        ],
        "counter_evidence": [
          "string"
        ],
        "open_questions": [
          "string"
        ]
      }
    ],
    "trend_summary": "string",
    "risk_register": [
      {
        "risk": "string",
        "likelihood": "low | medium | high",
        "impact": "low | medium | high",
        "mitigation": "string"
      }
    ]
  },
  "synthesis": {
    "core_insight": "string",
    "recommended_action": "string",
    "evidence_grade": "A | B | C | D",
    "what_would_change_the_conclusion": [
      "string"
    ]
  }
}
